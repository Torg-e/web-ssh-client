##############################################
# Security & Secrets
##############################################
SECRET_KEY=super-secure-secret-at-least-32-characters
DATABASE_URL=sqlite:////app/ssh_vault.db

# To get an valid Vault Encryption Key use: 
# openssl rand -base64 32 | tr '+/' '-_'
VAULT_ENCRYPTION_KEY=

##############################################
# Session & Cookie Security
##############################################
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true
WTF_CSRF_SSL_STRICT=true

##############################################
# Network & Proxy
##############################################
TRUSTED_PROXIES_COUNT=1
CORS_ALLOWED_ORIGINS=127.0.0.1:5000

##############################################
# Application
##############################################
EXTERNAL_PORT=5000
FLASK_ENV=production

##############################################
# SocketIO
##############################################
SOCKETIO_PING_TIMEOUT=120
SOCKETIO_PING_INTERVAL=25

##############################################
# Terminal Defaults
##############################################
TERMINAL_COLS=120
TERMINAL_ROWS=40

##############################################
# SSH
##############################################
SSH_KEEPALIVE=30

##############################################
# AI Integration
##############################################
OLLAMA_BASE_URL=http://ollama:11434
AI_ENABLED=true

##############################################
# Rate Limiting
##############################################
LOGIN_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT=300

##############################################
# Log Limits
##############################################
MAX_OUTPUT_LOG=500000
MAX_INPUT_LOG=100000
